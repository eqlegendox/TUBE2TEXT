# Copy this file to .env and fill in your keys.
# Or just open http://localhost:8000/setup after starting the server.

# Primary AI — free, no credit card needed
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Fallback AI — used automatically if Gemini hits its daily limit
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Notion integration token (starts with "secret_")
# Create one at: https://www.notion.so/my-integrations
NOTION_API_KEY=

# 32-character ID from your Notion database URL
# e.g. notion.so/6ea2c5cd3252837fa237015d39b81e35?v=...
NOTION_DATABASE_ID=

# Supadata API key — used to fetch YouTube transcripts (avoids cloud IP blocks)
# Get yours at: https://supadata.ai
SUPADATA_API_KEY=

# YouTube Data API v3 key — enables the /discover recommendations endpoint
# Enable "YouTube Data API v3" in Google Cloud Console → Credentials → API Key
YOUTUBE_DATA_API_KEY=

# Comma-separated list of allowed CORS origins (no trailing slash)
# In production set this to your Vercel URL: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Secret token to protect the /setup page in production
# Set to any random string (e.g. openssl rand -hex 16) and include it as
# the X-Setup-Token header when accessing /setup. Leave blank to disable the check locally.
SETUP_TOKEN=
