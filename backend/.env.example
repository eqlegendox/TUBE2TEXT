# Copy this file to .env and fill in your keys.
# Or just open http://localhost:8000/setup after starting the server.

# Primary AI — free, no credit card needed
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Fallback AI — used automatically if Gemini hits its daily limit
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Notion integration token (starts with "secret_")
# Create one at: https://www.notion.so/my-integrations
NOTION_API_KEY=

# 32-character ID from your Notion database URL
# e.g. notion.so/6ea2c5cd3252837fa237015d39b81e35?v=...
NOTION_DATABASE_ID=
